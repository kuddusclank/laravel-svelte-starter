        "types:check": "svelte-check --tsconfig ./tsconfig.json"
    },
    "devDependencies": {
        "@tailwindcss/vite": "4.2.1",
        "@types/node": "25.3.3",
        "axios": "^1.11.0",
        "concurrently": "9.2.1",
        "eslint": "10.0.2",
        "eslint-plugin-svelte": "3.15.0",
        "laravel-vite-plugin": "2.1.0",
        "prettier": "3.8.1",
        "prettier-plugin-svelte": "3.5.1",
        "prettier-plugin-tailwindcss": "0.7.2",
        "svelte-check": "4.4.4",
        "tailwindcss": "4.2.1",
        "typescript": "5.9.3",
        "vite": "7.3.1"
    },
    "dependencies": {
        "@inertiajs/svelte": "2.3.17",
        "@skeletonlabs/skeleton": "4.12.1",
        "@skeletonlabs/skeleton-svelte": "4.12.1",
        "@sveltejs/vite-plugin-svelte": "6.2.4",
